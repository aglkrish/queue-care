# Server port
PORT=5000

# MongoDB connection string
# Local:    mongodb://localhost:27017/queuecure
# Atlas:    mongodb+srv://<user>:<password>@<cluster>.mongodb.net/queuecure?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017/queuecure

# Comma-separated list of allowed origins for CORS / Socket.IO
# Example: http://localhost:5173,https://queuecure.vercel.app
CLIENT_ORIGIN=http://localhost:5173

# Node environment
NODE_ENV=development
